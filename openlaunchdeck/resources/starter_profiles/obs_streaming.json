{
  "name": "OBS Streaming",
  "id": "obs_streaming",
  "default_page": "main",
  "settings": {},
  "pages": [
    {
      "name": "Main",
      "id": "main",
      "buttons": {
        "A1": {
          "label": "Start Rec",
          "color": "red",
          "enabled": true,
          "dangerous": false,
          "notes": "Enable OBS WebSocket and enter the password if OBS requires authentication.",
          "action": {
            "type": "obs_websocket",
            "config": {
              "operation": "start_recording"
            }
          }
        },
        "A2": {
          "label": "Stop Rec",
          "color": "orange",
          "enabled": true,
          "dangerous": true,
          "action": {
            "type": "obs_websocket",
            "config": {
              "operation": "stop_recording"
            }
          }
        },
        "A3": {
          "label": "Show Cam",
          "color": "purple",
          "enabled": true,
          "dangerous": false,
          "action": {
            "type": "obs_websocket",
            "config": {
              "operation": "show_source",
              "scene_name": "Scene",
              "source_name": "Video Capture Device"
            }
          }
        },
        "A4": {
          "label": "Hide Cam",
          "color": "orange",
          "enabled": true,
          "dangerous": false,
          "action": {
            "type": "obs_websocket",
            "config": {
              "operation": "hide_source",
              "scene_name": "Scene",
              "source_name": "Video Capture Device"
            }
          }
        },
        "A5": {
          "label": "Mute",
          "color": "cyan",
          "enabled": true,
          "dangerous": false,
          "action": {
            "type": "obs_websocket",
            "config": {
              "operation": "mute_input",
              "input_name": "Mic/Aux"
            }
          }
        },
        "A6": {
          "label": "Unmute",
          "color": "green",
          "enabled": true,
          "dangerous": false,
          "action": {
            "type": "obs_websocket",
            "config": {
              "operation": "unmute_input",
              "input_name": "Mic/Aux"
            }
          }
        },
        "B1": {
          "label": "Open OBS",
          "color": "blue",
          "enabled": true,
          "dangerous": false,
          "action": {
            "type": "open_path",
            "config": {
              "path": "C:\\Program Files\\obs-studio\\bin\\64bit\\obs64.exe"
            }
          }
        },
        "B2": {
          "label": "Dashboard",
          "color": "green",
          "enabled": true,
          "dangerous": false,
          "action": {
            "type": "open_url",
            "config": {
              "url": "https://example.com/stream-dashboard"
            }
          }
        },
        "B3": {
          "label": "Clip",
          "color": "purple",
          "enabled": true,
          "dangerous": false,
          "action": {
            "type": "obs_websocket",
            "config": {
              "operation": "save_replay_buffer",
              "host": "127.0.0.1",
              "port": 4455,
              "start_if_stopped": true,
              "replay_verify_timeout_ms": 10000,
              "timeout_ms": 3000
            }
          }
        },
        "B4": {
          "label": "Screenshot",
          "color": "cyan",
          "enabled": true,
          "dangerous": false,
          "action": {
            "type": "obs_websocket",
            "config": {
              "operation": "save_screenshot",
              "host": "127.0.0.1",
              "port": 4455,
              "screenshot_folder": "",
              "screenshot_format": "png",
              "timeout_ms": 3000
            }
          }
        }
      }
    }
  ]
}
