{
  "name": "Minecraft Server",
  "id": "minecraft_server",
  "default_page": "main",
  "settings": {},
  "pages": [
    {
      "name": "Main",
      "id": "main",
      "buttons": {
        "A1": {
          "label": "Panel",
          "color": "blue",
          "enabled": true,
          "dangerous": false,
          "action": {
